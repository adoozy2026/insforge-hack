# --- Insforge ---
# From your Insforge project settings (https://insforge.dev/dashboard).
# Insforge does NOT expose a direct Postgres connection; all access is via REST.
INSFORGE_PROJECT_URL=https://<your-project>.insforge.app
INSFORGE_ANON_KEY=
INSFORGE_SERVICE_ROLE_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_RESEARCHER=claude-sonnet-4-6
ANTHROPIC_MODEL_SYNTHESIZER=claude-opus-4-7

# --- Orchestrator runtime ---
# true = serve seeded fixture data instead of hitting Claude web tools
FIXTURE_MODE=false
ORCHESTRATOR_LOG_LEVEL=info
POLL_INTERVAL_SECONDS=1.5

# --- Web (Next.js) ---
# Browser-visible Insforge config. Set the same values in Vercel project env.
NEXT_PUBLIC_INSFORGE_PROJECT_URL=https://<your-project>.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=
