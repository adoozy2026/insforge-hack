# --- Insforge ---
# From your Insforge project settings (https://insforge.dev/dashboard).
# Insforge does NOT expose a direct Postgres connection; all access is via REST.
INSFORGE_PROJECT_URL=https://abwh49kk.us-west.insforge.app
INSFORGE_ANON_KEY=
INSFORGE_SERVICE_ROLE_KEY=

# --- Google AI Studio (Gemini) ---
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_MODEL_RESEARCHER=gemini-3.5-flash
GEMINI_MODEL_SYNTHESIZER=gemini-2.5-pro

# --- Orchestrator runtime ---
# true = serve seeded fixture data instead of hitting Gemini + web tools
FIXTURE_MODE=false
ORCHESTRATOR_LOG_LEVEL=info
POLL_INTERVAL_SECONDS=1.5

# --- Extractor pool (Replicas cloud agent) ---
# Off until the Replicas GitHub app is installed on the target repo.
REPLICAS_ENABLED=false
REPLICAS_CLI_PATH=/Users/andrewwang/.bun/bin/replicas
REPLICAS_MIN_RUNS=3
REPLICAS_TARGET_REPO=adoozy2026/ShopprDiff.ai
# Find with: replicas env list — look for "Default <org>/<repo>"
REPLICAS_ENVIRONMENT_ID=

# --- Web (Next.js) ---
# Browser-visible Insforge config. Set the same values in Vercel project env.
NEXT_PUBLIC_INSFORGE_PROJECT_URL=https://abwh49kk.us-west.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=
